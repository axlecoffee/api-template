		"@types/jest": "^30.0.0",
		"@types/multer": "^2.1.0",
		"@types/supertest": "^7.2.0",
		"eslint": "^10.4.1",
		"prettier": "^3.8.3",
		"supertest": "^7.2.2",
		"ts-jest": "^29.4.11",
		"ts-node": "^10.9.2",
		"ts-node-dev": "^2.0.0",
